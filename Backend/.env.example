# ─── App ──────────────────────────────────────────────────────────────────────
ENV=development                          # development | staging | production
APP_NAME=Nerve AI
DEBUG=true

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nerve:nerve_secret@postgres:5432/nerveai
# For local dev without Docker:
# DATABASE_URL=postgresql+asyncpg://nerve:nerve_secret@localhost:5432/nerveai

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
# For local dev without Docker:
# REDIS_URL=redis://localhost:6379/0

# ─── Embedding Sidecar ────────────────────────────────────────────────────────
EMBEDDING_SERVICE_URL=http://embedding-service:8001
# For local dev without Docker:
# EMBEDDING_SERVICE_URL=http://localhost:8001

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PATH=/data/chromadb
# Collections
CHROMA_CLINICAL_COLLECTION=clinical_knowledge
CHROMA_MEMORY_COLLECTION=patient_memory

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440         # 24 hours

# ─── LLM Providers ────────────────────────────────────────────────────────────
# Groq — Llama-3 70B (Router, Guardrail) + Mixtral 8x7B (Onboarding)
# Get key at: https://console.groq.com
GROQ_API_KEY=gsk_CHANGE_ME

# Gemini 1.5 Flash — RAG generator, Memory Extractor, Vision Agent
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_CHANGE_ME

# Cohere Command R — Care Planner
# Get key at: https://dashboard.cohere.com
COHERE_API_KEY=CHANGE_ME

# ─── Model Names (change if using different tiers) ────────────────────────────
GROQ_ROUTER_MODEL=llama3-70b-8192
GROQ_GUARDRAIL_MODEL=llama3-70b-8192
GROQ_ONBOARDING_MODEL=mixtral-8x7b-32768
GEMINI_MODEL=gemini-1.5-flash
COHERE_MODEL=command-r

# ─── RAG Settings ─────────────────────────────────────────────────────────────
RAG_TOP_K=10                             # chunks retrieved before reranking
RAG_RERANK_TOP_N=5                       # chunks passed to LLM after reranking

# ─── Memory Settings ──────────────────────────────────────────────────────────
SESSION_WINDOW_SIZE=20                   # short-term memory sliding window
SESSION_TTL_SECONDS=7200                 # 2 hours
MEMORY_EXTRACT_EVERY_N_MESSAGES=10       # trigger extraction every N messages

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60                 # requests per user per minute on /chat

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://nerve-ai.com

# ─── Observability (optional — leave blank to disable) ───────────────────────
SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
